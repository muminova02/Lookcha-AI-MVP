
# Lookcha AI - Backend environment

# App
APP_NAME=Lookcha AI API
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated origins; "*" allows all in dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage
DATA_DIR=app/data
UPLOADS_DIR=app/storage/uploads

# AI try-on provider: "mock" | "nanobanana"
AI_PROVIDER=mock

# Generic provider keys (unused while AI_PROVIDER=mock)
AI_API_KEY=
AI_MODEL=

# NanoBanana Pro virtual try-on (used when AI_PROVIDER=nanobanana)
NANOBANANA_API_KEY=d5b6eab7a1dc181eb1039bbdccc46607
NANOBANANA_BASE_URL=https://api.nanobananaapi.ai
NANOBANANA_CALLBACK_URL=https://example.com/lookcha-callback
NANOBANANA_RESOLUTION=2K
NANOBANANA_ASPECT_RATIO=3:4

# Public base URL so external APIs can fetch locally-uploaded photos.
# Local dev: run `ngrok http 8000` and paste the https URL here.
# If empty and AI_PROVIDER=nanobanana, the backend safely falls back to mock.
PUBLIC_BASE_URL=
