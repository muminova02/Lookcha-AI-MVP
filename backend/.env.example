# Lookcha AI - Backend environment

# App
APP_NAME=Lookcha AI API
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated origins; "*" allows all in dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage
DATA_DIR=app/data
UPLOADS_DIR=app/storage/uploads

# AI try-on provider: "mock" for now. Later: "openai" | "gemini" | "replicate"
AI_PROVIDER=mock

# Real provider keys (unused while AI_PROVIDER=mock)
AI_API_KEY=
AI_MODEL=
